# Core server
PORT=3000

# Amadeus-backed features
# Deprecated as primary source: self-service registration is no longer reliable.
# Used by legacy provider only.
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Flight search provider
# Primary provider for real flight search data.
SERPAPI_API_KEY=

# Optional local fallback provider.
# Install punitarani/fli and ensure this command is available on PATH.
FLIGHT_FALLBACK_PROVIDER=fli
FLI_COMMAND=fli
# Reserved for a future fli HTTP sidecar integration.
FLI_MCP_URL=http://127.0.0.1:8000/mcp/

# OpenWeather-backed features
# Used by: /api/dashboard
OPENWEATHERMAP_API_KEY=

# Gemini-backed features
# Used by: /api/fun-score, /api/dashboard
GEMINI_API_KEY=
