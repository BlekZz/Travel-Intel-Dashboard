# Core server
PORT=3000

# Amadeus-backed features
# Deprecated as primary source: self-service registration is no longer reliable.
# Used by legacy provider only.
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Flight search provider
# Primary provider for real flight search data.
SERPAPI_API_KEY=

# Optional local fallback provider.
# Install punitarani/fli and ensure this command is available on PATH.
FLIGHT_FALLBACK_PROVIDER=fli
FLI_COMMAND=fli
# On Windows, if antivirus flags the pip-generated fli.exe launcher,
# point FLI_COMMAND to python.exe and the app will run: python -m fli.cli.main ...
# Example:
# FLI_COMMAND=C:\Users\<user>\.pyenv\pyenv-win\versions\3.13.11\python.exe
# Reserved for a future fli HTTP sidecar integration.
FLI_MCP_URL=http://127.0.0.1:8000/mcp/

# OpenWeather-backed features
# Used by: /api/dashboard
OPENWEATHERMAP_API_KEY=

# Gemini-backed features
# Used by: /api/fun-score, /api/booking-advice, /api/travelintel
GEMINI_API_KEY=
# Optional final fallback key.
# Use a key from a different Google AI Studio / Google Cloud project if you want real quota isolation.
GEMINI_API_KEY_SECONDARY=
# Default model. gemini-1.5-flash has a higher free-tier RPD than gemini-2.5-flash.
# Switch to gemini-2.5-flash for highest quality output (burns quota faster).
GEMINI_MODEL=gemini-1.5-flash
# SDK defaults to v1beta; keep configurable because model availability can differ by API version.
GEMINI_API_VERSION=v1beta
# travelintel shared cache tuning
TRAVEL_INTEL_CACHE_TTL_MS=43200000
TRAVEL_INTEL_LAST_KNOWN_GOOD_TTL_MS=604800000

# ── Dev mock mode ──────────────────────────────────────────────────────────────
# Set DEV_MOCK=true to skip ALL external API calls (Gemini, SerpApi, fli,
# OpenWeatherMap) and return one of two pre-written ideal datasets instead.
# Use this whenever working on UI/CSS to avoid burning quota.
# Set back to false only when explicitly testing real API responses.
DEV_MOCK=false
